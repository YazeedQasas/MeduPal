# Copy this to .env and fill in real values.
# The server reads these at startup.

# ── Groq (cloud LLM — fast & free tier available) ────────────────────────────
# Get key at https://console.groq.com — if set, Groq is used instead of Ollama
GROQ_API_KEY=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
GROQ_MODEL=llama-3.2-3b-preview

# ── Ollama (local fallback) ───────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=30

# ── RAG / Embeddings ─────────────────────────────────────────────────────────
EMBED_MODEL=nomic-embed-text
EMBED_TIMEOUT=15

# ── Supabase (backend only — use service role key, NOT the anon key) ─────────
SUPABASE_URL=https://zorhmeiilwavxbbvqvgy.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InpvcmhtZWlpbHdhdnhiYnZxdmd5Iiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3MDU2MTA0MiwiZXhwIjoyMDg2MTM3MDQyfQ.wl4bO7DgrJo8fjWGSuIMK9nsJ_U3whZvWFH9M84HiZo

# ── OpenAI TTS (optional) ────────────────────────────────────────────────────
OPENAI_API_KEY=
TTS_VOICE=nova
TTS_MODEL=tts-1-hd

# ── Whisper STT ──────────────────────────────────────────────────────────────
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
