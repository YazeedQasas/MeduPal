# Copy this to .env and fill in real values.
# The server reads these at startup.

# ── Groq (cloud LLM — fast & free tier available) ────────────────────────────
# Get key at https://console.groq.com — if set, Groq is used instead of Ollama
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Ollama (local fallback) ───────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=30

# ── RAG / Embeddings ─────────────────────────────────────────────────────────
EMBED_MODEL=nomic-embed-text
EMBED_TIMEOUT=15

# ── Supabase (backend only — use service role key, NOT the anon key) ─────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key-here

# ── OpenAI TTS (optional) ────────────────────────────────────────────────────
OPENAI_API_KEY=
TTS_VOICE=nova
TTS_MODEL=tts-1-hd

# ── Whisper STT ──────────────────────────────────────────────────────────────
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
